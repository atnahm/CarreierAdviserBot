# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/careeradviser"

# Redis
REDIS_URL="redis://localhost:6379/0"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# API keys (optional for compatibility)
OPENAI_API_KEY=""

# Server Configuration
PORT=3001
NODE_ENV="development"

# CORS Configuration
CORS_ORIGINS="http://localhost:5173"

# Per-client db support (multi-tenant manager may override this)
# CLIENT_DB_URL_CLIENTA="postgresql://client_a_user:client_a_pass@db-host:5432/client_a_db"
# CLIENT_DB_URL_CLIENTB="postgresql://client_b_user:client_b_pass@db-host:5432/client_b_db"